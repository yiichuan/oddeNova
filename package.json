{
  "name": "vibe-live-music",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "build:electron": "tsc -p electron/tsconfig.json",
    "dist:mac": "vite build && npm run build:electron && electron-builder --mac dmg"
  },
  "dependencies": {
    "@airjelly/sdk": "^0.1.0",
    "@anthropic-ai/sdk": "^0.90.0",
    "@strudel/codemirror": "^1.3.0",
    "@strudel/core": "^1.2.6",
    "@strudel/draw": "^1.2.6",
    "@strudel/mini": "^1.2.6",
    "@strudel/tonal": "^1.2.6",
    "@strudel/transpiler": "^1.2.6",
    "@strudel/webaudio": "^1.3.0",
    "openai": "^6.34.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@tailwindcss/vite": "^4.2.2",
    "@types/node": "^24.12.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "electron": "^41.3.0",
    "electron-builder": "^26.8.1",
    "eslint": "^9.39.4",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.4.0",
    "tailwindcss": "^4.2.2",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.0",
    "vite": "^8.0.4"
  },
  "build": {
    "appId": "com.vibelivemusic.app",
    "productName": "Vibe Live Music",
    "directories": {
      "output": "release"
    },
    "extraMetadata": {
      "main": "dist-electron/main.js",
      "type": "commonjs"
    },
    "files": [
      "dist-electron/**"
    ],
    "extraResources": [
      { "from": "dist", "to": "dist" }
    ],
    "mac": {
      "category": "public.app-category.music",
      "identity": "Developer ID Application",
      "notarize": true,
      "target": [
        { "target": "dmg", "arch": ["arm64", "x64"] }
      ]
    },
    "dmg": {
      "title": "Vibe Live Music"
    }
  }
}
